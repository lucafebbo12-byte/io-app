{
  "name": "checkpoint-paint",
  "version": "1.0.0",
  "description": "Multiplayer spray-paint .io game",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node server/index.js\" \"vite\"",
    "build": "vite build",
    "server": "node server/index.js",
    "cap:sync": "vite build && npx cap sync",
    "cap:android": "vite build && npx cap sync && npx cap run android",
    "cap:ios": "vite build && npx cap sync && npx cap run ios"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "@capacitor/android": "^5.6.0",
    "@capacitor/cli": "^5.6.0",
    "@capacitor/core": "^5.6.0",
    "@capacitor/ios": "^5.6.0",
    "concurrently": "^8.2.2",
    "phaser": "^3.60.0",
    "phaser3-rex-plugins": "^1.80.6",
    "socket.io-client": "^4.7.2",
    "vite": "^5.0.8"
  }
}
